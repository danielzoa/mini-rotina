<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="@dimen/screen_padding">

    <TextView
        android:id="@+id/textTimerActivityName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textTimerTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="64sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/progressTimer"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:progressDrawable="@drawable/progress_timer" />

    <TextView
        android:id="@+id/textTimerFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:minHeight="64dp"
        android:text="@string/timer_feedback_start"
        android:textColor="@color/text_secondary"
        android:textSize="22sp" />

    <Button
        android:id="@+id/buttonPause"
        style="@style/PrimaryActionButton"
        android:layout_marginTop="20dp"
        android:text="@string/action_pause" />

    <Button
        android:id="@+id/buttonBackHome"
        style="@style/SecondaryActionButton"
        android:layout_marginTop="12dp"
        android:text="@string/action_back_home" />

</LinearLayout>
