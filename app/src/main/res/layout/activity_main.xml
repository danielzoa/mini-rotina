<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            android:id="@+id/textAppTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textAppSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/home_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/textStars"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_reward_badge"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonBrushTeeth"
            style="@style/ActivityButton"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/activity_mint"
            android:text="@string/activity_brush_teeth" />

        <Button
            android:id="@+id/buttonSchool"
            style="@style/ActivityButton"
            android:backgroundTint="@color/activity_blue"
            android:text="@string/activity_school" />

        <Button
            android:id="@+id/buttonCleanRoom"
            style="@style/ActivityButton"
            android:backgroundTint="@color/activity_yellow"
            android:text="@string/activity_clean_room" />

        <Button
            android:id="@+id/buttonHomework"
            style="@style/ActivityButton"
            android:backgroundTint="@color/activity_lilac"
            android:text="@string/activity_homework" />

        <Button
            android:id="@+id/buttonReading"
            style="@style/ActivityButton"
            android:backgroundTint="@color/activity_green"
            android:text="@string/activity_reading" />

        <Button
            android:id="@+id/buttonSleep"
            style="@style/ActivityButton"
            android:backgroundTint="@color/activity_night"
            android:text="@string/activity_sleep" />

        <Button
            android:id="@+id/buttonFreePlay"
            style="@style/ActivityButton"
            android:backgroundTint="@color/activity_pink"
            android:text="@string/activity_free_play" />

    </LinearLayout>
</ScrollView>
